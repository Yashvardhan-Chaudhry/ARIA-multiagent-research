# Copy to `.env` and fill in your own keys. Never commit the real .env.

# Anthropic API key — powers ARIA v3 (the multi-agent crew).
# NOTE: v1 and v2 run on a LOCAL model via Ollama (qwen2.5:3b) and need NO API key —
# just a running Ollama server at http://localhost:11434.
CLAUDE_API_KEY=sk-ant-your-key-here

# Tavily web-search key — ARIA's `web_search` tool (v1 + v3 researcher/fact-checker)
TAVILY_API_KEY=tvly-your-key-here

# Separate Tavily key for the A/B harness (v3/Tavily_Research_blackbox.py),
# so its /research credit burn is isolated from the crew. Optional.
TAVILY_API_KEY2=tvly-your-second-key-here

# dev.to API key — v3 publisher node uploads the final draft as an UNPUBLISHED draft. Optional.
DEV_API_KEY=your-devto-key-here
